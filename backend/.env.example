PORT=5005
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/MoodMaps
JWT_SECRET=replace_with_a_long_random_secret
NODE_ENV=production

# Your deployed Vercel frontend URL (comma-separated if multiple)
CLIENT_URL=https://your-app.vercel.app

